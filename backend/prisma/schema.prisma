generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  INSTRUCTOR
  LEARNER
}

enum EnrollmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ScormAttemptStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum CourseResumeMode {
  LAST_POSITION
  RESTART
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  courses     Course[]
  enrollments Enrollment[]
  scormAttempts ScormAttempt[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  passwordHash String
  role         UserRole @default(LEARNER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  scormAttempts ScormAttempt[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Course {
  id           String   @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  scormVersion String   @default("SCORM_2004")
  packagePath  String?
  isPublished  Boolean  @default(false)
  resumeMode   CourseResumeMode @default(LAST_POSITION)
  allowRetake  Boolean  @default(true)
  reviewAfterCompletion Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  scormAttempts ScormAttempt[]

  @@index([tenantId])
}

model Enrollment {
  id          String           @id @default(cuid())
  tenantId    String
  userId      String
  courseId    String
  status      EnrollmentStatus @default(NOT_STARTED)
  progress    Int              @default(0)
  score       Float?
  attempts    Int              @default(0)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, courseId])
}

model ScormAttempt {
  id               String            @id @default(cuid())
  tenantId         String
  userId           String
  courseId         String
  attemptNumber    Int
  status           ScormAttemptStatus @default(IN_PROGRESS)
  completionStatus String? 
  successStatus    String?
  scoreRaw         Float?
  scoreScaled      Float?
  startedAt        DateTime          @default(now())
  endedAt          DateTime?
  durationMs       Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  runtimeValues ScormRuntimeValue[]
  itemStates    ScormAttemptItemState[]

  @@unique([tenantId, userId, courseId, attemptNumber])
  @@index([tenantId, userId, courseId])
  @@index([tenantId, courseId])
}

model ScormRuntimeValue {
  id        String   @id @default(cuid())
  attemptId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempt ScormAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, key])
  @@index([attemptId])
}

model ScormAttemptItemState {
  id           String   @id @default(cuid())
  attemptId    String
  itemKey      String
  launchUrl    String
  progress     Int      @default(0)
  quizScore    Float?
  successStatus String?
  completionStatus String?
  location     String?
  isQuiz       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attempt ScormAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, itemKey])
  @@index([attemptId])
  @@index([attemptId, updatedAt])
}
